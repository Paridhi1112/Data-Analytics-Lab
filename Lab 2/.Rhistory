library(ggplot2)
setwd("C:/Users/parid/Documents/RPI/Spring 2026/Data Analytics/Lab/Lab 2")
house.data <- read.csv("NY-House-Dataset.csv", header=TRUE)
View(house.data)
summary(house.data)
colSums(is.na(house.data))
house.data.clean <- na.omit(house.data)
# calculate outlier bounds first
Q1 <- quantile(house.data.clean$PRICE, 0.25, na.rm=TRUE)
Q3 <- quantile(house.data.clean$PRICE, 0.75, na.rm=TRUE)
IQR <- Q3 - Q1
lower.bound <- Q1 - 1.5 * IQR
upper.bound <- Q3 + 1.5 * IQR
# check for outliers in Price
boxplot(house.data.clean$PRICE, main="Price Distribution")
# remove extreme outliers (optional - adjust based on your data)
house.data.clean <- house.data.clean[house.data.clean$PRICE >= lower.bound &
house.data.clean$PRICE <= upper.bound, ]
# check distributions
hist(house.data.clean$PRICE, main="Price Distribution", xlab="Price")
hist(house.data.clean$PROPERTYSQFT, main="Property SqFt Distribution", xlab="Property SqFt")
hist(house.data.clean$BEDS, main="Beds Distribution", xlab="Beds")
hist(house.data.clean$BATH, main="Bath Distribution", xlab="Bath")
# Model 1: Price ~ PropertySqFt #
lin.mod1 <- lm(PRICE ~ PROPERTYSQFT, house.data.clean)
summary(lin.mod1)
# plot most significant variable vs Price
ggplot(house.data.clean, aes(x = PROPERTYSQFT, y = PRICE)) +
geom_point() +
stat_smooth(method = "lm") +
labs(title = "Model 1: Price vs Property SqFt",
x = "Property Square Feet",
y = "Price")
# residual plot
ggplot(lin.mod1, aes(x = .fitted, y = .resid)) +
geom_point() +
geom_hline(yintercept = 0) +
labs(title='Model 1: Residual vs. Fitted Values Plot',
x='Fitted Values',
y='Residuals')
# Model 2: Price ~ Beds #
lin.mod2 <- lm(PRICE ~ BEDS, house.data.clean)
summary(lin.mod2)
# plot most significant variable vs Price
ggplot(house.data.clean, aes(x = BEDS, y = PRICE)) +
geom_point() +
stat_smooth(method = "lm") +
labs(title = "Model 2: Price vs Beds",
x = "Number of Bedrooms",
y = "Price")
# residual plot
ggplot(lin.mod2, aes(x = .fitted, y = .resid)) +
geom_point() +
geom_hline(yintercept = 0) +
labs(title='Model 2: Residual vs. Fitted Values Plot',
x='Fitted Values',
y='Residuals')
#Model 3: Price ~ Bath #
lin.mod3 <- lm(PRICE ~ BATH, house.data.clean)
summary(lin.mod3)
# plot most significant variable vs Price
ggplot(house.data.clean, aes(x = BATH, y = PRICE)) +
geom_point() +
stat_smooth(method = "lm") +
labs(title = "Model 3: Price vs Bath",
x = "Number of Bathrooms",
y = "Price")
# residual plot
ggplot(lin.mod3, aes(x = .fitted, y = .resid)) +
geom_point() +
geom_hline(yintercept = 0) +
labs(title='Model 3: Residual vs. Fitted Values Plot',
x='Fitted Values',
y='Residuals')
# Compare Models #
# R-squared comparison
cat("\nModel Comparison:\n")
cat("Model 1 (Price ~ PropertySqFt) R-squared:", summary(lin.mod1)$r.squared, "\n")
cat("Model 2 (Price ~ Beds) R-squared:", summary(lin.mod2)$r.squared, "\n")
cat("Model 3 (Price ~ Bath) R-squared:", summary(lin.mod3)$r.squared, "\n")
